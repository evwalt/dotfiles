# --- daily combos ---
# Just sync lazy.nvim plugins and then run `dua` regularly (every day, week, or two weeks)
# "daily update"
# alias du="pxu && ngu && ru && bu"
# alias du="sudo -v && pxu && ngu && ru && mps"
alias du="pxu && ngu && ru && bob update"
# "daily log"
# alias dl="pxl && ngl && rl && bl"
# alias dl="pxl && ngl && rl && mpl && fhd"
# alias dl="pxl && ngl && rl && fhd"
alias dl="pxl && ngl && rl"
# "yadm track all"
# alias uta="u add ~/.config/nvim/lazy-lock.json ~/pipx-packages.txt ~/global-npm-packages.txt ~/rust-version.txt ~/brew-leaves.txt ~/brew-list.txt ~/brew-list-cask.txt && ucm 'chore: update deps' && ups"
alias uta="u add ~/.config/nvim/lazy-lock.json ~/pipx-packages.txt ~/global-npm-packages.txt ~/rust-version.txt ~/cargo-packages.txt ~/ports.txt && ucm 'chore: update deps' && ups"
# "daily update, log, and yadm track all"
# alias dua="du && dl && uta && bd"
alias dua="du && dl && uta"

# --- macports ---
alias mps="sudo port selfupdate"
alias mpu="sudo port upgrade outdated && sudo port uninstall inactive"
alias mpl="port installed > ports.txt"

# --- homebrew ---
# "brew update"
alias bu="brew update --verbose && brew upgrade --verbose && brew cleanup --verbose --prune=all"
alias bd="brew doctor"
# "brew log"
alias bl="brew leaves > ~/brew-leaves.txt && brew list > ~/brew-list.txt && brew list --cask > ~/brew-list-cask.txt"
# "brew display logs"
alias bdl="less ~/brew-leaves.txt && less ~/brew-list.txt && less ~/brew-list-cask.txt"

# --- git ---
# git develop and main, or git deploy
alias gdp="git checkout main && git merge dev && git push && git checkout dev"
alias gs="git status"
alias gcm="git commit -m"
alias gam="git add . && git commit -m"
alias gps="git push"
alias gf="git fetch"
alias gpl="git pull"
alias gd="git diff"
alias gds="git diff | delta --side-by-side"
alias gsh="git show"
alias gshs="git show | delta --side-by-side"
alias gdw="git diff --word-diff"
alias gdc="git diff --color-words"
alias gl="git log"
alias glo="git log --oneline"
alias gre="git restore"

# --- firefox history ---
alias fhd="~/scripts/firefox-history-dump.zsh"

# --- java ---
alias jr="javac -Xlint:unchecked Main.java && java Main"

# --- go ---
# run these inside a Go module
alias goo="go list -m -u all"
alias gou="go get -u ./... && go mod tidy"
alias gol="go list -m all > ~/go-packages.txt"

# --- misc ---
alias cdd="cd ~/Library/CloudStorage/Dropbox/"

# --- npm ---
alias ngo="npm -g outdated"
alias ngu="npm -g update"
# "npm -g log"
alias ngl="npm -g list > ~/global-npm-packages.txt"
# "npm -g display logs"
alias ngdl="less ~/global-npm-packages.txt"
alias nrd="npm run dev"
alias nrb="npm run build"
alias nt="npm test"

# --- pipx ---
alias pxu="pipx upgrade-all"
# "pipx log"
alias pxl="pipx list > ~/pipx-packages.txt"
# "pipx display logs"
alias pxdl="less ~/pipx-packages.txt"

# --- postgres ---
alias pgstart='pg_ctl -D ~/postgres-data -l ~/postgres-data/server.log start'
alias pgstop='pg_ctl -D ~/postgres-data stop'
alias pgstatus='pg_ctl -D ~/postgres-data status'

# --- rustup ---
alias ru="rustup update"
# "rustc log"
alias rl="rustup toolchain list > ~/rust-toolchains.txt && cargo install --list > ~/cargo-packages.txt"
# "rustc display logs"
alias rdl="less ~/rust-toolchains.txt && less ~/cargo-packages.txt"

# --- tmuxinator ---
alias tx="tmuxinator"
alias txs="tmuxinator start"
alias txss="tmuxinator start session"

# --- yadm ---
alias u="yadm "
alias ua="yadm add"
alias us="yadm status"
alias ucm="yadm commit -m"
alias ud="yadm diff"
alias uds="yadm diff | delta --side-by-side"
alias ush="yadm show"
alias ushs="yadm show | delta --side-by-side"
alias udw="yadm diff --word-diff"
alias udc="yadm diff --color-words"
alias ups="yadm push"
alias uan="yadm add ~/.config/nvim/"
alias uavs="yadm add ~/Library/Application\ Support/Code/User/settings.json"
alias uavk="yadm add ~/Library/Application\ Support/Code/User/keybindings.json"
alias ul="yadm log"
alias ulo="yadm log --oneline"

# --- zsh ---
alias l="ls -laF"
